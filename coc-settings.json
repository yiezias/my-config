{
  "suggest.noselect": true,
  "languageserver": {
    "ccls": {
            "command": "ccls",
                  "filetypes": ["c", "cpp", "cuda", "objc", "objcpp"],
                  "rootPatterns": [".ccls-root", "compile_commands.json"],
            "initializationOptions": {
              "cache": {
                          "directory": ".ccls-cache"
                            
              },
              "client": {
                          "snippetSupport": true
                            
              }
                    
            }
                
    }
      
  },
  "coc.preferences.extensionUpdateCheck": "daily"
  
}

